<mujoco model="drawer_visual_object">
  <asset>
    <!-- Preprocessed from uploaded Drawer.stl: millimeters -> meters, xy-centered, bottom z=0. -->
    <mesh name="drawer_mesh" file="../meshes/drawer_visual_m.stl"/>
    <material name="drawer_mat" rgba="0.55 0.45 0.35 1" specular="0.25" shininess="0.3"/>
  </asset>

  <worldbody>
    <!-- Required by robosuite MujocoXMLObject: top body contains object body + bottom/top/radius sites. -->
    <body>
      <body name="object">
        <!-- Visual mesh only. Do not use raw CAD mesh for collision. -->
        <geom name="drawer_visual" type="mesh" mesh="drawer_mesh" material="drawer_mat"
              contype="0" conaffinity="0" group="1"/>

        <!-- Bright debug visual proxy. Remove later after confirming placement. -->
        <!-- <geom name="drawer_debug_visual_box" type="box"
              pos="0 0 0.030" size="0.040 0.055 0.035"
              contype="0" conaffinity="0" group="0"
              rgba="1 0.15 0.05 1"/> -->

        <!-- Simple collision proxy based on uploaded STL bounds: 0.070 x 0.095 x 0.060 m. -->
        <geom name="drawer_collision" type="box" pos="0 0 0.030" size="0.035 0.0475 0.030"
              rgba="0.2 0.2 0.2 0.0" density="80" friction="1.2 0.01 0.001"
              solimp="0.998 0.998 0.001" solref="0.002 1" group="0"/>

        <site name="drawer_center" pos="0 0 0.030" size="0.008" rgba="1 0 0 1"/>
      </body>
      <site name="bottom_site" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
      <site name="top_site" pos="0 0 0.060" size="0.005" rgba="0 0 0 0"/>
      <site name="horizontal_radius_site" pos="0.060 0.060 0.030" size="0.005" rgba="0 0 0 0"/>
    </body>
  </worldbody>
</mujoco>
