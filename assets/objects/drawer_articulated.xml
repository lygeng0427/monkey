<mujoco model="drawer_articulated_object">
  <!--
    Articulated drawer task object.

    The uploaded drawer CAD (drawer_visual_m.stl) is a single solid drawer block
    with a recessed front-face handle (no protrusion) and NO separate cabinet.
    So here the CAD mesh is the *sliding drawer*, and the cabinet it pulls out of
    is built from primitive boxes. A graspable D-handle is also added as a
    primitive (the CAD recess cannot be pinched).

    Local frame: z=0 is the cabinet bottom (rests on the table). The drawer opens
    along +y (the front / handle face). The environment rotates the whole object
    (set_euler) so this +y opening faces the robot.
  -->
  <asset>
    <mesh name="drawer_mesh" file="../meshes/drawer_visual_m.stl"/>
    <material name="drawer_mat"  rgba="0.55 0.45 0.35 1" specular="0.25" shininess="0.3"/>
    <material name="cabinet_mat" rgba="0.35 0.33 0.30 1" specular="0.20" shininess="0.2"/>
    <material name="handle_mat"  rgba="0.15 0.15 0.18 1" specular="0.60" shininess="0.6"/>
  </asset>

  <worldbody>
    <body>
      <body name="object">
        <!-- Static cabinet frame (no joint => welded to world). Open on +y. -->
        <body name="frame">
          <geom name="cab_bottom" type="box" pos="0 0 0.004"        size="0.048 0.0525 0.004"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_left"   type="box" pos="-0.044 -0.0025 0.040" size="0.004 0.050 0.032"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_right"  type="box" pos="0.044 -0.0025 0.040"  size="0.004 0.050 0.032"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_back"   type="box" pos="0 -0.0565 0.040"  size="0.048 0.004 0.032"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_top"    type="box" pos="0 -0.0025 0.076"  size="0.048 0.050 0.004"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
        </body>

        <!-- Sliding drawer: CAD mesh (visual) + box collision + added grasp handle.
             NB: geom/body names must NOT start with the object name ("drawer"), or
             robosuite 1.5.x double-prefixes them (drawer_ + drawer_... ) and crashes. -->
        <body name="tray" pos="0 0 0.009">
          <joint name="slide" type="slide" axis="0 1 0" pos="0 0 0"
                 range="0 0.16" limited="true" damping="1" frictionloss="0.5" armature="0.01"/>

          <geom name="tray_visual" type="mesh" mesh="drawer_mesh" material="drawer_mat"
                contype="0" conaffinity="0" group="1"/>
          <geom name="tray_collision" type="box" pos="0 0 0.030" size="0.034 0.046 0.029"
                rgba="0.2 0.2 0.2 0" density="200" friction="1 0.01 0.001"
                solimp="0.998 0.998 0.001" solref="0.002 1" group="0"/>

          <!-- Added graspable D-handle protruding from the front (+y) face (not in CAD). -->
          <geom name="handle_post_l" type="box" pos="-0.014 0.051 0.032" size="0.004 0.004 0.006"
                material="handle_mat" friction="1 0.01 0.001" group="1"/>
          <geom name="handle_post_r" type="box" pos="0.014 0.051 0.032"  size="0.004 0.004 0.006"
                material="handle_mat" friction="1 0.01 0.001" group="1"/>
          <geom name="handle" type="cylinder" fromto="-0.018 0.058 0.032 0.018 0.058 0.032" size="0.005"
                material="handle_mat" friction="2 0.05 0.001"
                solimp="0.998 0.998 0.001" solref="0.002 1" group="1"/>

          <site name="handle_site" pos="0 0.058 0.032" size="0.008" rgba="1 0 0 0.3"/>
        </body>
      </body>

      <site name="bottom_site"            pos="0 0 0"        size="0.005" rgba="0 0 0 0"/>
      <site name="top_site"               pos="0 0 0.080"    size="0.005" rgba="0 0 0 0"/>
      <site name="horizontal_radius_site" pos="0.060 0 0.040" size="0.005" rgba="0 0 0 0"/>
    </body>
  </worldbody>
</mujoco>
