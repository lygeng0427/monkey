<mujoco model="drawer_articulated_object">
  <!--
    Articulated drawer task object.

    The uploaded drawer CAD (drawer_visual_m.stl) is a single solid drawer block
    with a recessed front-face handle (no protrusion) and NO separate cabinet.
    So here the CAD mesh is the *sliding drawer*, and the cabinet it pulls out of
    is built from primitive boxes. A graspable D-handle is also added as a
    primitive (the CAD recess cannot be pinched).

    The whole object is scaled 2x relative to the raw CAD (mesh scale="2 2 2" and
    all primitive dims doubled) so the drawer and handle are large enough to see
    where the gripper grasps. Raw CAD drawer is 0.070 x 0.095 x 0.060 m -> 2x is
    0.140 x 0.190 x 0.120 m.

    Local frame: z=0 is the cabinet bottom. The whole object is welded to the world
    (the `object`/`frame` body has no joint), so it stays FIXED wherever it is
    placed and needs no physical support. The env places it ~0.27 m above the table
    so the handle sits at world z~1.15, where the Panda wrist can hold a ~45 deg
    "between top-down and horizontal" grasp cleanly (at a table-height handle, z~0.88,
    the wrist can only point horizontal with the arm fully extended up, ~0.6 m away).
    The cabinet simply FLOATS at that height with nothing below it (a pedestal/riser
    was tried but is purely cosmetic and was removed as unwanted; a tall table does
    not work because raising the work surface to z~1.07 traps the gripper (reset
    z~1.01) under the tabletop). The drawer opens along +y (the front / handle face).
    The environment rotates the whole object (set_euler) so this +y opening faces the
    robot.

    The static cabinet has BOTH collision geoms (group="0") and visual twin geoms
    (group="1", contype/conaffinity=0). robosuite renders with
    render_collision_mesh=False, which hides group 0, so the cabinet needs the
    group-1 twins to be visible. Without them the cabinet is invisible and the
    drawer looks like it slides out into empty space (nothing staying put).
  -->
  <asset>
    <mesh name="drawer_mesh" file="../meshes/drawer_visual_m.stl" scale="2 2 2"/>
    <material name="drawer_mat"  rgba="0.55 0.45 0.35 1" specular="0.25" shininess="0.3"/>
    <material name="cabinet_mat" rgba="0.35 0.33 0.30 1" specular="0.20" shininess="0.2"/>
    <material name="handle_mat"  rgba="0.15 0.15 0.18 1" specular="0.60" shininess="0.6"/>
  </asset>

  <worldbody>
    <body>
      <body name="object">
        <!-- Static cabinet frame (no joint => welded to world). Open on +y.
             Each wall is a group="0" collision box plus a group="1" visual twin
             (same pos/size/material, contype/conaffinity=0) so the cabinet is
             actually drawn (render_collision_mesh=False hides group 0). -->
        <body name="frame">
          <geom name="cab_bottom" type="box" pos="0 0 0.008"        size="0.096 0.105 0.008"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_left"   type="box" pos="-0.088 -0.005 0.080" size="0.008 0.100 0.064"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_right"  type="box" pos="0.088 -0.005 0.080"  size="0.008 0.100 0.064"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <geom name="cab_back"   type="box" pos="0 -0.113 0.080"  size="0.096 0.008 0.064"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>
          <!-- Top ends at the drawer body front (local y ~+0.056) so it does NOT
               overhang the protruding loop handle (local y 0.056..0.095); an
               overhanging lip would block a top-down grasp of the handle. -->
          <geom name="cab_top"    type="box" pos="0 -0.0245 0.152"  size="0.096 0.0805 0.008"
                material="cabinet_mat" friction="1 0.01 0.001" group="0"/>

          <!-- Visual twins (rendered; no collision). -->
          <geom name="cab_bottom_visual" type="box" pos="0 0 0.008"        size="0.096 0.105 0.008"
                material="cabinet_mat" contype="0" conaffinity="0" group="1"/>
          <geom name="cab_left_visual"   type="box" pos="-0.088 -0.005 0.080" size="0.008 0.100 0.064"
                material="cabinet_mat" contype="0" conaffinity="0" group="1"/>
          <geom name="cab_right_visual"  type="box" pos="0.088 -0.005 0.080"  size="0.008 0.100 0.064"
                material="cabinet_mat" contype="0" conaffinity="0" group="1"/>
          <geom name="cab_back_visual"   type="box" pos="0 -0.113 0.080"  size="0.096 0.008 0.064"
                material="cabinet_mat" contype="0" conaffinity="0" group="1"/>
          <geom name="cab_top_visual"    type="box" pos="0 -0.0245 0.152"  size="0.096 0.0805 0.008"
                material="cabinet_mat" contype="0" conaffinity="0" group="1"/>
        </body>

        <!-- Sliding drawer: CAD mesh (visual) + collision proxies. The CAD already
             has a real bag-style LOOP handle on the front (+y) face (an arch at
             mid-height, hole opening vertically; front bar at local y~0.090, z~0.064,
             spanning local x ~+/-0.026). We grasp that real handle; NO extra handle
             is added. NB: geom/body names must NOT start with the object name
             ("drawer"), or robosuite 1.5.x double-prefixes them and crashes. -->
        <body name="tray" pos="0 0 0.018">
          <joint name="slide" type="slide" axis="0 1 0" pos="0 0 0"
                 range="0 0.32" limited="true" damping="0.5" frictionloss="0.1" armature="0.02"/>

          <geom name="tray_visual" type="mesh" mesh="drawer_mesh" material="drawer_mat"
                contype="0" conaffinity="0" group="1"/>
          <!-- Body collision: a LOW slab covering only the bottom of the drawer block
               (local y -0.095..+0.056), topping out BELOW the handle bar (tray-local
               z top ~0.045 vs bar at z~0.064) so the tilted gripper descending onto
               the bar does not graze / catch on the block top. The drawer is on a
               1-DOF slide joint (height fixed), so a short collision still keeps it
               seated; the upper block is visual-only (tray_visual). -->
          <geom name="tray_collision" type="box" pos="0 -0.019 0.0235" size="0.068 0.0755 0.0215"
                rgba="0.2 0.2 0.2 0" density="200" friction="1 0.01 0.001"
                solimp="0.998 0.998 0.001" solref="0.002 1" group="0"/>

          <!-- Collision for the CAD loop's FRONT BAR (the graspable part): a thin slab
               matching the mesh bar, with grip friction. The gripper approaches along
               world +x (the pull axis), slips this bar into its finger slot, clamps
               vertically (fingers along z), and pulls -x. Invisible (rgba alpha 0);
               the CAD mesh provides the visible handle. -->
          <geom name="handle_bar" type="cylinder" fromto="-0.026 0.090 0.064 0.026 0.090 0.064" size="0.012"
                rgba="0.2 0.2 0.2 0" density="200" friction="4 0.1 0.001"
                solimp="0.998 0.998 0.001" solref="0.002 1" group="0"/>

          <site name="handle_site" pos="0 0.090 0.064" size="0.012" rgba="1 0 0 0.3"/>
        </body>
      </body>

      <site name="bottom_site"            pos="0 0 0"        size="0.005" rgba="0 0 0 0"/>
      <site name="top_site"               pos="0 0 0.160"    size="0.005" rgba="0 0 0 0"/>
      <site name="horizontal_radius_site" pos="0.120 0 0.080" size="0.005" rgba="0 0 0 0"/>
    </body>
  </worldbody>
</mujoco>
